@model IEnumerable<CitasApp.Models.Cita>
@{
    // Recuperamos los catálogos que enviamos desde el controlador
    var pacientes = ViewBag.Pacientes as List<CitasApp.Models.Paciente>;
    var medicos = ViewBag.Medicos as List<CitasApp.Models.Medico>;
}

<h1 class="display-4 my-4">Agenda de Citas</h1>

<table class="table table-bordered table-striped" style="max-width: 850px;">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Paciente</th>
            <th>Médico</th>
            <th>Motivo</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            // Buscamos el nombre correspondiente al ID de forma dinámica
            var nombrePaciente = pacientes?.FirstOrDefault(p => p.Id == c.PacienteId)?.Nombre ?? "Desconocido";
            var nombreMedico = medicos?.FirstOrDefault(m => m.Id == c.MedicoId)?.Nombre ?? "Desconocido";

            <tr>
                <td>@c.Fecha</td>
                <td>@c.FechaHora</td>
                <td>@nombrePaciente</td>
                <td>@nombreMedico</td>
                <td>@c.Motivo</td>
                <td>
                    @if (c.Estado == "Confirmada")
                    {
                        <span class="badge bg-success">@c.Estado</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">@c.Estado</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>