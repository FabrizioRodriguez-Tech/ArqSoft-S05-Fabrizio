@model IEnumerable<dynamic>
<h2>Agenda Completa de Citas</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Fecha y Hora</th>
            <th>Paciente</th>
            <th>Médico</th>
            <th>Motivo</th>
            <th>Estado</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Fecha.ToString("dd/MM/yyyy") - @item.Hora.ToString("HH:mm")</td>
                <td>@item.NombrePaciente</td>
                <td>@item.NombreMedico</td>
                <td>@item.Motivo</td>
                <td><span class="badge @(item.Estado == "Confirmada" ? "bg-success" : "bg-warning")">@item.Estado</span></td>
            </tr>
        }
    </tbody>
</table>