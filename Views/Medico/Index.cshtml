@model IEnumerable<CitasApp.Models.Medico>
<h2>Nuestros Médicos</h2>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre Completo</th>
            <th>Especialidad</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>Dr. @item.Nombre @item.Apellido</td>
                <td>@item.Especialidad</td>
                <td><a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info btn-sm">Ver Licencia</a></td>
            </tr>
        }
    </tbody>
</table>