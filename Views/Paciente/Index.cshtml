@model IEnumerable<CitasApp.Models.Paciente>

<h1 class="display-4 my-4">Pacientes registrados</h1>

<table class="table table-bordered table-striped" style="max-width: 700px;">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Nombre</td>
                <td>@p.Email</td>
                <td>@p.Telefono</td>
                <td><a href="/Paciente/Detalle/@p.Id" class="btn btn-link p-0">Ver detalle</a></td>
            </tr>
        }
    </tbody>
</table>