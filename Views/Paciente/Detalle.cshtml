@model CitasApp.Domain.Models.Paciente
@{
    ViewData["Title"] = "Detalle del Paciente";
    var citas = ViewBag.Citas as List<CitasApp.Domain.Models.Cita> ?? new List<CitasApp.Domain.Models.Cita>();
}

<div class="container my-4" style="max-width: 800px; font-family: sans-serif;">
    <h1 class="display-5 mb-4">Detalle del Paciente</h1>

    <div class="card mb-4 box-shadow">
        <div class="card-body">
            <h4 class="card-title text-primary">@Model.Nombre</h4>
            <hr />
            <p><strong>ID Paciente:</strong> @Model.Id</p>
            <p><strong>Correo Electrónico:</strong> @Model.Email</p>
            <p><strong>Teléfono de Contacto:</strong> @Model.Telefono</p>
        </div>
    </div>

    <h3 class="mb-3 text-secondary">Citas Programadas</h3>

    @if (citas.Count == 0)
    {
        <div class="alert alert-info">Este paciente no tiene citas registradas en el sistema.</div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Hora</th>
                    <th>Motivo</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cita in citas)
                {
                    <tr>
                        <td>@cita.Fecha</td>
                        <td>@cita.FechaHora</td>
                        <td>@cita.Motivo</td>
                        <td>
                            @if (cita.Estado == "Confirmada")
                            {
                                <span class="badge bg-success">@cita.Estado</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@cita.Estado</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-4">
        <a href="/Paciente" class="btn btn-secondary">Volver a la lista</a>
    </div>
</div>